# Backend
# For easiest local dev you can omit DATABASE_URL and SQLite will be used.
# For Postgres (docker or hosted), set:
DATABASE_URL=postgresql+psycopg://agentins:agentins@localhost:5432/agentins
API_HOST=0.0.0.0
API_PORT=8000

# Alpaca (paper by default)
ALPACA_ENV=paper  # paper|live
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Trader settings
RUN_MODE=shadow  # shadow|live
MAX_DAILY_LOSS_PCT=0.02
MAX_POSITION_PCT=0.10
MAX_CONCURRENT_POSITIONS=10
MAX_ORDERS_PER_MINUTE=20

# Mobile/Web
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_N8N_URL=http://localhost:5678/webhook
